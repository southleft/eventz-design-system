{
  "name": "doxyz",
  "private": true,
  "packageManager": "pnpm",
  "workspaces": ["packages/*", "tools/*"],
  "scripts": {
    "build": "pnpm --filter doxyz build",
    "build:tokens": "pnpm --filter doxyz build:tokens",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "type-check": "pnpm -r type-check",
    "sb": "pnpm --filter doxyz storybook",
    "sb:build": "pnpm --filter doxyz build:storybook",
    "pack:ui": "pnpm --filter doxyz pack --dry-run"
  }
}
