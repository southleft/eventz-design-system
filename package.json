{
  "name": "eventz-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm --filter @eventz-ui/core build",
    "build:tokens": "pnpm --filter @eventz-ui/core build:tokens",
    "build-storybook": "pnpm --filter @eventz-ui/core build-storybook",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "type-check": "tsc -b --noEmit",
    "sb": "pnpm --filter @eventz-ui/core storybook",
    "sb:build": "pnpm --filter @eventz-ui/core build:storybook",
    "pack:ui": "pnpm --filter @eventz-ui/core exec npm pack --dry-run",
    "agents:sync": "node scripts/agents-sync.mjs",
    "agents:verify": "node scripts/agents-sync.mjs && markdown-link-check -q AGENTS/*.md",
    "check:doc-blocks": "node scripts/check-doc-blocks.mjs --changed-only",
    "check:doc-blocks:strict": "node scripts/check-doc-blocks.mjs --changed-only --require-header",
    "check:doc-blocks:all": "node scripts/check-doc-blocks.mjs"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.1.1",
    "js-yaml": "^4.1.0",
    "markdown-link-check": "^3.11.2",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
