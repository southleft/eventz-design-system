{
  "name": "doxyz-monorepo",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "build": "pnpm --filter @doxyz/core build",
    "build:tokens": "pnpm --filter @doxyz/core build:tokens",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "type-check": "pnpm -r type-check",
    "sb": "pnpm --filter @doxyz/core storybook",
    "sb:build": "pnpm --filter @doxyz/core build:storybook",
    "pack:ui": "pnpm --filter @doxyz/core exec npm pack --dry-run"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "jest": "^30.1.1",
    "ts-jest": "^29.4.1"
  }
}
