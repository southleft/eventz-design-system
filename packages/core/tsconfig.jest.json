{
  "compilerOptions": {
    "composite": true,
    "noEmit": true,

    // Keep ESM + modern resolution consistent with the repo
    "module": "esnext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "types": ["jest", "node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.jest"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.spec.ts",
    "src/**/*.spec.tsx",
    "src/__tests__/**/*",
    "jest.setup.ts",
    "jest.setup.tsx"
  ],
  "exclude": ["dist", "build", "node_modules"]
}
