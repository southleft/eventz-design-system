{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "composite": true,
    "esModuleInterop": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ESNext",
    "paths": {
      "@/*": ["./src/*"],
      "@doxyz-ui/core/server-components": ["./src/index.server-components.ts"],
      "@doxyz-ui/core/client-components": ["./src/index.client-components.ts"],
      "@doxyz-ui/core/icons": ["./src/index.icons.ts"],
      "@doxyz-ui/core/utilities": ["./src/index.utilities.ts"]
    },
    "tsBuildInfoFile": "node_modules/.cache/tsbuildinfo.jest",
    "types": ["jest", "node"]
  },
  "exclude": ["dist", "build", "node_modules"],
  "include": ["src/**/*.ts", "src/**/*.tsx", "tests/**/*.ts", "tests/**/*.tsx"]
}
