{
  "name": "@doxyz/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/styles.css"
  },
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "radix-ui": "^1.4.3",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "build": "vite build && pnpm run build:tokens && pnpm run build:css",
    "build:tokens": "node scripts/build-tokens.js",
    "build:css": "pnpm exec tailwindcss -i ./styles/css/utilities.css -o ./dist/styles.css --minify",
    "storybook": "pnpm run build:tokens && pnpm run build:css && storybook dev -p 6006",
    "build:storybook": "pnpm run build:tokens && pnpm run build:css && storybook build",
    "clean": "rimraf dist",
    "rebuild": "pnpm run clean && pnpm run build",
    "dev": "pnpm run build:tokens && pnpm run build:css && vite build --watch",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "tsc -b",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.0",
    "@storybook/addon-a11y": "^9.1.1",
    "@storybook/addon-docs": "^9.1.1",
    "@storybook/addon-vitest": "^9.1.1",
    "@storybook/react-vite": "^9.1.1",
    "@tailwindcss/cli": "^4",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@tsconfig/node20": "^20.1.6",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.4",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@vitest/browser": "^3.2.4",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-storybook": "^9.1.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "playwright": "^1.54.2",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.0",
    "storybook": "^9.1.1",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^4.1.11",
    "tailwindcss-radix": "^4.0.2",
    "typescript": "^5.9.2",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.1",
    "vitest": "^3.2.4"
  }
}
