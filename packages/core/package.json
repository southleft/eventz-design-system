{
  "name": "@doxyz-ui/core",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "exports": {
    "./server-components": {
      "types": "./dist/server-components.d.ts",
      "import": "./dist/server-components.mjs"
    },
    "./client-components": {
      "types": "./dist/client-components.d.ts",
      "import": "./dist/client-components.mjs"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.mjs"
    },
    "./utilities": {
      "types": "./dist/utilities.d.ts",
      "import": "./dist/utilities.mjs"
    },
    "./styles.css": "./dist/styles.css"
  },
  "types": "./dist/server-components.d.ts",
  "sideEffects": false,
  "engines": {
    "node": ">=20.0.0"
  },
  "peerDependencies": {
    "radix-ui": "^1.4.3",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "scripts": {
    "build": "vite build --mode lib && pnpm run build:tokens && pnpm run build:css",
    "build:tokens": "node scripts/build-tokens.js",
    "build:css": "pnpm exec tailwindcss -i ./styles/css/index.css -o ./dist/styles.css --minify",
    "chromatic": "pnpm run build-storybook && chromatic --project-token=chpt_758de87493596a5 --storybook-build-dir=storybook-static --no-interactive --exit-once-uploaded",
    "dev:css": "pnpm exec tailwindcss -i ./styles/css/index.css -o ./styles/css/styles.css --watch",
    "storybook": "pnpm exec concurrently -n CSS,SB -c cyan,magenta \"pnpm run dev:css\" \"pnpm exec storybook dev -p 6006\"",
    "build-storybook": "pnpm run build:tokens && pnpm run dev:css && storybook build",
    "clean": "rimraf dist",
    "rebuild": "pnpm run clean && pnpm run build",
    "dev": "pnpm run build:tokens && pnpm run build:css && vite build --watch",
    "format": "prettier --write .",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "jest --config jest.config.ts --maxWorkers=50%",
    "test:watch": "jest --config jest.config.ts --watch --maxWorkers=25%",
    "test:coverage": "jest --config jest.config.ts --coverage",
    "test:list": "jest --config jest.config.ts --listTests",
    "test:dev": "jest --config jest.config.ts --clearCache && jest --coverage --maxWorkers=50%",
    "type-check": "tsc -b",
    "prepublishOnly": "pnpm run build",
    "watch:tokens": "pnpm exec chokidar \"styles/tokens/**/*.{json,js,ts}\" -c \"node scripts/build-tokens.js\"",
    "watch:tokens:once": "node scripts/build-tokens.js && pnpm run watch:tokens",
    "ci:guard": "node scripts/verify-server-bundle.js"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.0",
    "@eslint/js": "^9.35.0",
    "@storybook/addon-a11y": "^9.1.1",
    "@storybook/addon-docs": "^9.1.1",
    "@storybook/react": "^9.1.4",
    "@storybook/react-vite": "^9.1.1",
    "@tailwindcss/cli": "^4",
    "@tailwindcss/postcss": "^4.1.13",
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@tsconfig/node20": "^20.1.6",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.4",
    "@typescript-eslint/eslint-plugin": "^8.39.0",
    "@typescript-eslint/parser": "^8.39.0",
    "@vitejs/plugin-react": "^4.3.0",
    "chokidar-cli": "^3.0.0",
    "chromatic": "^13.1.5",
    "concurrently": "^8.2.2",
    "eslint": "^9.33.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jest-dom": "^5.5.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^9.1.1",
    "eslint-plugin-testing-library": "^7.6.8",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest-environment-jsdom": "^29.7.0",
    "playwright": "^1.54.2",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.0",
    "storybook": "^9.1.1",
    "style-dictionary": "^4.4.0",
    "tailwindcss": "^4.1.11",
    "tailwindcss-radix": "^4.0.2",
    "typescript-eslint": "^8.43.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^3.9.1"
  },
  "dependencies": {
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/themes": "^3.2.1",
    "@testing-library/user-event": "^14.6.1",
    "rsuite": "^5.83.3"
  }
}
